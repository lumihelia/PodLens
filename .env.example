# Gemini API key. Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Model used for interpretation. gemini-2.5-pro is recommended for fidelity.
# You can switch to gemini-2.5-flash for faster / cheaper runs.
PODLENS_MODEL=gemini-2.5-pro

# Language of the interpretation output (the transcript itself can be any language).
# zh = Chinese, en = English
PODLENS_OUTPUT_LANG=zh

# Path to your personal profile file used for the personal-mapping layer.
PODLENS_PROFILE=profile.md

# --- YouTube caption fetching (only used when you pass a YouTube URL) ---
# If YouTube bot-checks or rate-limits you (HTTP 429 / "Sign in to confirm"),
# let yt-dlp use your browser's login cookies. Set to: chrome / safari / firefox / edge
# PODLENS_COOKIES_FROM_BROWSER=chrome

# Subtitle language preference for yt-dlp (comma-separated, regex allowed).
# Default grabs English variants. For other languages e.g. zh.*,en.*,.*
# PODLENS_SUB_LANGS=en.*,en

# --- Publishing to a static site + RSS feed (podlens publish) ---
# The public base URL of your site. Set this to your custom subdomain once DNS
# is wired; until then the GitHub Pages project URL is used.
PODLENS_SITE_URL=https://lumihelia.github.io/PodLens
# Custom domain written into docs/CNAME (leave blank to use the github.io URL).
# e.g. lens.yourdomain.com
PODLENS_CUSTOM_DOMAIN=
# Public branding shown on the site and in the feed.
PODLENS_SITE_TITLE=PodLens
PODLENS_SITE_DESC=播客的忠实解读:先还原,再用大白话讲清楚。
PODLENS_SITE_AUTHOR=lumihelia
# Heading that marks where the private layers begin. Everything from this
# heading onward is NEVER published. Default = start of the personal layers.
PODLENS_PRIVATE_CUTOFF=## 证据锚定洞察
